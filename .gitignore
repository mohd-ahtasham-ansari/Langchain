# ==============================================================================
# STRICT WHITELIST APPROACH: Ignore everything except specific code files
# ==============================================================================

# 1. Ignore EVERYTHING by default
*

# 2. Allow Git to traverse directories (needed for the rules below to work)
!*/

# 3. Whitelist the specific file types you WRITE code in
!*.py
!*.ipynb
!*.md
!*.txt
!*.json

# 4. Whitelist necessary configuration files
!.gitignore
!pyproject.toml
!.python-version
!README.md

# ==============================================================================
# 5. RE-IGNORE specific directories (overriding the directory traversal above)
# ==============================================================================

# Virtual Environments
.venv/
venv/
env/

# IDE and Cache
__pycache__/
.vscode/
.idea/
.ipynb_checkpoints/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# LangChain / Vector Stores / Data
chroma_db/
chroma/
logs/
data/
datasets/
models/

# Explicitly ignore environment variables/keys (Double protection)
.env
*.key
*.pem
*.sqlite3
*.db
